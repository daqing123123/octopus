{
  "name": "octopus",
  "version": "0.1.0",
  "description": "🐙 八爪鱼 - 企业级AI办公平台",
  "private": true,
  "workspaces": [
    "src/backend",
    "src/frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev -w @octopus/backend",
    "dev:frontend": "npm run dev -w @octopus/frontend",
    "build": "npm run build -w @octopus/backend && npm run build -w @octopus/frontend",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:prod": "docker-compose up -d"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
